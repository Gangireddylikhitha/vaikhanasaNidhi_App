# Server
PORT=5000
JWT_SECRET=your_jwt_secret_here
MONGODB_URI=mongodb://127.0.0.1:27017/vaikhanasa-nidhi
CLIENT_ORIGIN=http://localhost:5173

# Cloudinary (required for image uploads + delete on remove)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Panchangam — local Drik calculations (Swiss Ephemeris / Lahiri ayanamsa)
# No external API required. Optional defaults for Tirupati:
PANCHANGAM_LAT=13.6288
PANCHANGAM_LON=79.4192
# Daily IST hour to precompute today + tomorrow into MongoDB (default 5)
PANCHANGAM_SYNC_HOUR_IST=5
# Optional: prefetch missing year dates overnight (local compute — no API cost)
PANCHANGAM_PREFETCH_PER_NIGHT=8
PANCHANGAM_PREFETCH_YEAR=2026
# Calendar: amanta (Telugu/Nithra) or purnimanta
PANCHANGAM_CALENDAR_TYPE=amanta

# Firebase Android push (optional — for mobile app only)
# Download service account JSON from Firebase Console
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Hour in IST to send daily sloka + panchangam (default 6)
NOTIFICATION_HOUR_IST=6
# Must match notification channel id created in the Android app
ANDROID_NOTIFICATION_CHANNEL_ID=vaikhanasa_daily
